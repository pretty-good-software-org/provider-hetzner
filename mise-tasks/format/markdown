#!/usr/bin/env bash
#MISE description="Format repository Markdown with mdformat"
#MISE depends=["setup:mdformat"]
set -euo pipefail

# Recompute the content-addressed path instead of trusting an inherited export.
source "${MISE_PROJECT_ROOT:?MISE_PROJECT_ROOT must be set by mise}/mise-tasks/setup/mdformat-env"
mdformat .
